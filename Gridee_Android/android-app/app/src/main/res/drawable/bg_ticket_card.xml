<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="200dp"
    android:height="200dp"
    android:viewportWidth="200"
    android:viewportHeight="200">

    <!-- 1. Full Card Background (White) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
          M 24,0
          L 176,0
          A 24,24 0 0 1 200,24
          L 200,90
          A 10,10 0 0 0 200,110
          L 200,176
          A 24,24 0 0 1 176,200
          L 24,200
          A 24,24 0 0 1 0,176
          L 0,110
          A 10,10 0 0 0 0,90
          L 0,24
          A 24,24 0 0 1 24,0
          Z" />

    <!-- 2. Bottom Section "Frosted Glass" Effect (Subtle Grey) -->
    <path
        android:fillColor="#F8F9FA"
        android:pathData="
          M 0,100
          L 200,100
          A 10,10 0 0 0 200,110
          L 200,176
          A 24,24 0 0 1 176,200
          L 24,200
          A 24,24 0 0 1 0,176
          L 0,110
          A 10,10 0 0 0 0,100
          Z" />

    <!-- 3. Card Outline (Clean & Professional) -->
    <!-- Using #E0E0E0 (Standard Light Grey) for a crisp, paper-like edge definition -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#E0E0E0"
        android:strokeWidth="1"
        android:pathData="
          M 24,0
          L 176,0
          A 24,24 0 0 1 200,24
          L 200,90
          A 10,10 0 0 0 200,110
          L 200,176
          A 24,24 0 0 1 176,200
          L 24,200
          A 24,24 0 0 1 0,176
          L 0,110
          A 10,10 0 0 0 0,90
          L 0,24
          A 24,24 0 0 1 24,0
          Z" />
</vector>
